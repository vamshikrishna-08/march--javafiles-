<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>EmployeeManagement</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  

<servlet>
<servlet-name>AddEmployee</servlet-name>
<servlet-class>com.employee.AddEmployee</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>AddEmployee</servlet-name>
<url-pattern>/AddEmployee</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>ListEmployeeServlet</servlet-name>
<servlet-class>com.employee.ListEmployeeServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>ListEmployeeServlet</servlet-name>
<url-pattern>/ListEmployeeServlet</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>DeleteEmployeeServlet</servlet-name>
<servlet-class>com.employee.DeleteEmployeeServlet</servlet-class>
</servlet>

<servlet-mapping>
<servlet-name>DeleteEmployeeServlet</servlet-name>
<url-pattern>/DeleteEmployeeServlet</url-pattern>
</servlet-mapping>

</web-app>